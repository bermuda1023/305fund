# Server
PORT=3001
JWT_SECRET=change-me-to-a-random-string
NODE_ENV=development
DEV_UNIVERSAL_ADMIN=0
CLIENT_URL=http://localhost:5173
INVESTOR_TARGET_URL=https://305opportunityfund.com/investor-site/investors.html#opportunity
INVESTOR_GATE_PASSWORD=
# Prefer hash in production. Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
INVESTOR_GATE_PASSWORD_HASH=
DB_PATH=./brickell-fund.db
DATABASE_URL=

# FRED API (free key from https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Email (SendGrid or Resend)
SENDGRID_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=info@305opportunityfund.com
NDA_SIGN_NOTIFY_EMAILS=jamesanfossi@hotmail.com,lancefraser89@gmail.com

# SMS (Twilio - optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# File storage
UPLOAD_DIR=./uploads
STORAGE_BACKEND=local

# Object storage (S3/R2) - set STORAGE_BACKEND=s3 in production
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Fixed investor NDA source (prefer storage key in production)
INVESTOR_NDA_STORAGE_KEY=
INVESTOR_NDA_PDF_PATH=

# Optional AI parsing for statement ingestion
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional bank feed integrations (future wiring)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
