{
  "name": "@brickell/server",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:pg": "tsx src/db/pg-migrate.ts",
    "db:sync:pg": "tsx src/db/pg-sync-from-sqlite.ts",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "tsc --noEmit",
    "test": "node -e \"console.log('No server tests configured yet')\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@brickell/engine": "workspace:*",
    "@brickell/shared": "workspace:*",
    "@fontsource/dancing-script": "^5.2.8",
    "@pdf-lib/fontkit": "^1.1.1",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
